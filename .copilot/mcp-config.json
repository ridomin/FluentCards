{
  "mcpServers": {
    "EXAMPLE-github": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/github-mcp-server"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "adaptive-cards-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "adaptive-cards-mcp"
      ]
    }
  }
}
